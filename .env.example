# Postgres — get a free one at https://neon.tech or https://supabase.com
DATABASE_URL=postgres://user:pass@host:5432/pullvault?sslmode=require

# Redis — get a free one at https://upstash.com
REDIS_URL=rediss://default:pass@host:6379

# Auth
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Pokemon TCG API (optional — works without a key on free tier)
POKEMON_TCG_API_KEY=

# WebSocket / Server
PORT=3000

# Default starting balance for new users (USD, in cents)
DEFAULT_BALANCE_CENTS=100000
